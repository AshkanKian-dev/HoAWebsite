# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration
DB_PATH=./database/hoa.db

# RCON Configuration
RCON_HOST=roejin.com
RCON_PORT=27029
RCON_PASSWORD=your_rcon_password_here
RCON_TIMEOUT_MS=10000

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_SECRET=your_paypal_webhook_secret_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=noreply@yourdomain.com

# Security Configuration
# Generate strong secrets using: openssl rand -hex 32
JWT_SECRET=change_this_secret_generate_strong_random_value
ADMIN_API_KEY=change_this_key_generate_strong_random_value
SESSION_SECRET=change_this_secret_generate_strong_random_value

# Admin account (created automatically on first server start)
ADMIN_EMAIL=admin@heartofacheron.com
ADMIN_PASSWORD=change_this_to_a_strong_password

# Steam OpenID Configuration
# Get your API key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here
STEAM_REALM=http://localhost:3000
STEAM_RETURN_URL=http://localhost:3000/api/auth/steam/callback

# CORS Configuration (comma-separated list of allowed origins)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500

# Application Settings
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000
DELIVERY_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info


# Game Server Configuration
GAME_SERVER_IP=roejin.com
GAME_SERVER_PORT=7775
GAME_QUERY_PORT=27012
MAX_PLAYERS=50



# Apple Pay Configuration
# Get merchant ID from: https://developer.apple.com/account/resources/identifiers/list/merchant
APPLE_PAY_MERCHANT_ID=merchant.com.yourdomain.yourapp
APPLE_PAY_DOMAIN=yourdomain.com
APPLE_PAY_DISPLAY_NAME=Heart of Acheron

# Google Pay Configuration
# Get merchant ID from: https://pay.google.com/business/console
GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id
GOOGLE_PAY_MERCHANT_NAME=Heart of Acheron

# AMP Configuration
# AMP API URL (e.g., https://your-amp-instance.com/api/v1/)
AMP_API_URL=
AMP_USERNAME=heartofacheron
AMP_PASSWORD=your_amp_password_here
# AMP Instance ID (found in AMP dashboard)
AMP_INSTANCE_ID=

# AMP Configuration
# AMP API URL (e.g., https://your-amp-instance.com/api/v1/)
AMP_API_URL=
AMP_USERNAME=heartofacheron
AMP_PASSWORD=your_amp_password_here
# AMP Instance ID (found in AMP dashboard)
AMP_INSTANCE_ID=
